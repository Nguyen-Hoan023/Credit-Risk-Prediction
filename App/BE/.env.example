# Môi trường chạy app: development | staging | production
ENVIRONMENT=development

# Database URL
# Local (Khuyên dùng khi test): postgresql://postgres:123456@localhost:5432/novabank_local
# Supabase Production (Chỉ dùng khi deploy): postgresql://postgres:[PASSWORD]@aws-1-ap-northeast-1.pooler.supabase.com:6543/postgres
DATABASE_URL=postgresql://postgres:123456@localhost:5432/novabank_local

# Khóa bảo mật Admin API Key (Bắt buộc phải truyền trong Header X-Admin-Key khi xóa dữ liệu)
# Nếu bỏ trống (""), API xóa /api/history sẽ tự động bị KHÓA hoàn toàn để an toàn.
ADMIN_API_KEY=super-secret-admin-key-2026

# CORS Allowed Origins (Phân cách bởi dấu phẩy)
ALLOWED_ORIGINS=http://localhost:3000,http://localhost:3001
